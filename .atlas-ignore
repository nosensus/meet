# Atlas Ignore File
# Patterns listed here will be excluded from atlas generation

# Package manager directories
node_modules/
vendor/
.venv/
venv/
env/
__pycache__/

# Build output directories
dist/
build/
out/
.next/
.nuxt/
.output/
.svelte-kit/

# Version control
.git/
.svn/
.hg/

# Test coverage and reports
coverage/
.nyc_output/
htmlcov/

# Temporary and cache files
tmp/
temp/
cache/
.cache/
*.log

# IDE and editor directories
.idea/
.vscode/
*.swp
*.swo

# Generated files (customize as needed)
# *.generated.ts
# *.min.js
# *.min.css

# OS-specific files
.DS_Store
Thumbs.db

# Project-specific exclusions (add below)
# legacy/
# deprecated/

# ---
# Configuration overrides (YAML format)
# Uncomment and customize as needed:
#
# confidence:
#   project_type: 0.8    # Threshold for auto-classifying project type
#   domain: 0.6          # Threshold for including domains
#   prompt_threshold: 0.5 # When to prompt user for confirmation
#
# custom_domains:
#   - name: legacy_code
#     location: src/legacy
#     purpose: Deprecated code pending migration
#     confidence: low
